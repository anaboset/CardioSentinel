"""Environment variables template — copy to .env and fill in values."""

# Groq LLM API (required for patient communication agent)
GROQ_API_KEY=gsk_your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Logging
LOG_LEVEL=INFO

# LangSmith Observability (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_your-key-here
LANGCHAIN_PROJECT=cardiosentinel

# API Configuration
CORS_ORIGINS=*
PORT=8000

# UI (optional Streamlit)
UI_THEME=dark

# openFDA drug interaction API (opt-in; local DB used by default)
OPENFDA_ENABLED=false

# Database (optional, future use)
DATABASE_URL=sqlite:///cardiosentinel.db
